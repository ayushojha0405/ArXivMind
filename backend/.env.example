# API Keys
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: legacy/unused keys
OPENAI_API_KEY=your_openai_api_key_here
HUGGINGFACEHUB_API_TOKEN=your_huggingface_api_token_here
HF_TOKEN=your_hf_token_here

# PostgreSQL Database (Render will provide this)
DATABASE_URL=postgresql://user:password@hostname:5432/dbname

# CORS Origins (Your Vercel URL)
CORS_ORIGINS=http://localhost:5173,https://your-vercel-app.vercel.app

# Security
SECRET_KEY=your_randomly_generated_secret_key_here

# Vector store (local ChromaDB path or remote Chroma server)
CHROMA_DB_PATH=./chroma_db
# CHROMA_HOST=your-chroma-host.example.com
# CHROMA_PORT=8000
# CHROMA_SSL=false
# CHROMA_API_KEY=

# Optional: Redis for distributed rate limiting across workers
# REDIS_URL=redis://localhost:6379
