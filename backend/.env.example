# API Keys
OPENAI_API_KEY=your_openai_api_key_here

# HuggingFace token for lightweight dynamic LLM routing
HUGGINGFACEHUB_API_TOKEN=your_huggingface_api_token_here
HF_TOKEN=your_hf_token_here

# PostgreSQL Database (Render will provide this)
DATABASE_URL=postgresql://user:password@hostname:5432/dbname

# CORS Origins (Your Vercel URL)
CORS_ORIGINS=http://localhost:5173,https://your-vercel-app.vercel.app

# Security
SECRET_KEY=your_randomly_generated_secret_key_here
